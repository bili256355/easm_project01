# ==============================================================================
# .gitignore for easm_project01
# ==============================================================================
# Policy:
# - Do NOT ignore directories merely because they are named output/outputs/result/
#   results/figure/figures/plot/plots/artifact/artifacts.
# - Normal small result files are allowed by default, including:
#   .csv, .json, .txt, .md, .png, .jpg, .jpeg, .pdf, .docx, .xlsx, .pptx.
# - Large scientific/binary data outputs remain ignored, including:
#   .nc, .npy, .npz, .pkl, .pickle, .joblib, .h5, .hdf5, .zarr, archives.
#
# Important:
# - .gitignore only affects untracked files.
# - Files already tracked by Git will continue to appear in changed files until
#   they are removed from the Git index with `git rm --cached`.
# ==============================================================================


# ------------------------------------------------------------------------------
# 1. Project documentation and root-level durable logs
# ------------------------------------------------------------------------------

!README.md
!**/README.md
!STRUCTURE_MANIFEST.txt
!**/STRUCTURE_MANIFEST.txt
!VERSION_POLICY.md
!**/VERSION_POLICY.md
!DEPENDENCY_MANIFEST.json
!**/DEPENDENCY_MANIFEST.json

!ROOT_LOG_*.md
!ROOT_LOG_INDEX_OLD_LOGS_CONSOLIDATION_TABLE.csv
!README_root_log_consolidation_v1_a.md


# ------------------------------------------------------------------------------
# 2. Python cache and build artifacts
# ------------------------------------------------------------------------------

__pycache__/
**/__pycache__/
*.py[cod]
*$py.class
*.so
*.pyd
.Python

build/
dist/
.eggs/
*.egg-info/
*.egg
pip-wheel-metadata/


# ------------------------------------------------------------------------------
# 3. Jupyter temporary files
# ------------------------------------------------------------------------------

.ipynb_checkpoints/
**/.ipynb_checkpoints/


# ------------------------------------------------------------------------------
# 4. Local virtual environments and local-only configuration
# ------------------------------------------------------------------------------

.venv/
venv/
env/
ENV/

.env
.env.*
*.env
.python-version


# ------------------------------------------------------------------------------
# 5. IDE / editor / OS local files
# ------------------------------------------------------------------------------

.idea/
.vscode/
*.code-workspace
*.sublime-project
*.sublime-workspace

.DS_Store
Thumbs.db


# ------------------------------------------------------------------------------
# 6. Temporary / backup files
# ------------------------------------------------------------------------------

*.tmp
*.temp
*.bak
*.backup
*.old
*.orig
*.swp
*.swo
~$*
*~


# ------------------------------------------------------------------------------
# 7. Runtime logs and old scattered engineering logs
# ------------------------------------------------------------------------------
# New durable logs should be written at the project root as ROOT_LOG_*.md.
# Old-style scattered logs remain ignored to prevent log sprawl.

*.log
**/logs/
**/log/

**/UPDATE_LOG*.md
**/ROOT_PROJECT_LOG*.md
**/CURRENT_ENGINEERING_MANIFEST*.md
**/PATCH_README*.md
**/PATCH_MANIFEST*.md
**/PATCH_FILE_LIST*.txt

# Re-allow root consolidated logs after broad log ignore rules.
!ROOT_LOG_*.md
!ROOT_LOG_INDEX_OLD_LOGS_CONSOLIDATION_TABLE.csv
!README_root_log_consolidation_v1_a.md


# ------------------------------------------------------------------------------
# 8. Large scientific data and generated binary array outputs
# ------------------------------------------------------------------------------
# These stay ignored even when located inside output/outputs/results directories.
# If a specific file must be versioned, add it intentionally with:
#   git add -f path\to\file.npz

*.nc
*.nc4
*.grib
*.grb
*.grb2

*.h5
*.hdf
*.hdf5
*.zarr/

*.npy
*.npz
*.pkl
*.pickle
*.joblib


# ------------------------------------------------------------------------------
# 9. Large archives / compressed bundles
# ------------------------------------------------------------------------------

*.zip
*.7z
*.rar
*.tar
*.tar.gz
*.tgz


# ------------------------------------------------------------------------------
# 10. Directory policy note
# ------------------------------------------------------------------------------
# output/, outputs/, result/, results/, figure/, figures/, plot/, plots/,
# artifact/, and artifacts/ are intentionally NOT ignored by directory name.
# Small files inside them can be tracked normally.
# Empty directories are still not tracked by Git; add a .gitkeep file if needed.
# ==============================================================================
